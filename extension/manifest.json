{
  "manifest_version": 3,
  "name": "ChatGPT Brain Bridge",
  "version": "0.1.0",
  "description": "Bridge your real ChatGPT tab to a local programmatic server.",
  "permissions": [],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
