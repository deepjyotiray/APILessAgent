{
  "name": "chatgpt-agent",
  "version": "0.2.0",
  "description": "ChatGPT-powered coding agent with Ollama fallback — Mac app + CLI",
  "type": "module",
  "main": "app/main.cjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/cli.ts",
    "chat": "tsx src/cli.ts",
    "chrome:attach": "tsx src/chrome-attach.ts",
    "bridge:server": "tsx src/bridge-server.ts",
    "agent": "tsx src/site-agent.ts",
    "agent:tui": "tsx src/agent-tui.ts",
    "api:server": "tsx src/api-server.ts",
    "app": "electron app/main.cjs",
    "app:dev": "concurrently \"npm run api:server\" \"electron app/main.cjs\"",
    "app:build": "electron-builder --mac",
    "app:pack": "electron-builder --mac --dir"
  },
  "keywords": [
    "chatgpt",
    "agent",
    "coding-assistant",
    "ollama",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "blessed": "^0.1.81",
    "playwright": "^1.59.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.27",
    "@types/node": "^24.12.2",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "electron": "^36.9.5",
    "electron-builder": "^26.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "com.agent.app",
    "productName": "Agent",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "app/assets/icon.icns"
    },
    "files": [
      "app/**/*",
      "src/**/*",
      "node_modules/**/*",
      "tsconfig.json",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "extension",
        "to": "extension"
      }
    ]
  }
}
